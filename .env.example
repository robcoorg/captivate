# Copy to `.env` for local dev. Never commit real secrets.
#
# Production (captivate.icu): set these in the host (e.g. AWS App Runner env / secrets).
# Staging: use the SAME variable names with a non-production DATABASE_URL and keys.

# PostgreSQL — required for dashboard/API data (503 if unset)
DATABASE_URL=postgresql://user:pass@localhost:5432/nanostudio

# Anthropic — required for AI task runs (503 if unset for those routes)
ANTHROPIC_API_KEY=sk-ant-api-key-placeholder

PORT=3000
NODE_ENV=development

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Email — Resend (https://resend.com)
# Add your sending domain in the Resend dashboard, then set SPF/DKIM/DMARC DNS records.
RESEND_API_KEY=re_
EMAIL_FROM=NanoStudio <hello@captivate.icu>

# Stripe — required for billing (checkout, webhooks, customer portal)
# All keys are live-mode only. Never use test keys in production.
STRIPE_SECRET_KEY=sk_live_
STRIPE_PUBLISHABLE_KEY=pk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe subscription price IDs (live mode) — one per paid tier
STRIPE_PRICE_STARTER=price_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_STUDIO=price_

# Stripe one-time credit pack price IDs (live mode)
# Create as one-time Payment products in Stripe Dashboard
STRIPE_PRICE_CREDITS_50=price_
STRIPE_PRICE_CREDITS_150=price_
STRIPE_PRICE_CREDITS_500=price_
